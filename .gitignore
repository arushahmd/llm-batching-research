# Reports: ignore all by default
reports/*

# Keep official master reports
!reports/master/
!reports/master/**

# Keep generation metric summaries only
!reports/generation_eval_summaries/
!reports/generation_eval_summaries/**

# Keep plots
!reports/plots/
!reports/plots/**

# Optional: keep archived lightweight CSV/JSON summaries
!reports/archive/
!reports/archive/**

# Never track prediction dumps
reports/**/predictions.csv

# Notebook checkpoints
.ipynb_checkpoints/